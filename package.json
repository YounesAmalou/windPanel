{
  "name": "windpanel",
  "description": "manifest.json description",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n extension,demo -c cyan,magenta \"bun run dev:extension\" \"bun run dev:demo\"",
    "dev:extension": "wxt",
    "dev:demo": "bun --cwd demo dev",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "demo:build": "bun --cwd demo/windpanel-demo build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "@wxt-dev/module-svelte": "^2.0.5",
    "concurrently": "^9.2.1",
    "svelte": "^5.55.8",
    "svelte-check": "^4.4.8",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  }
}
