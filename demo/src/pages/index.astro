---
import Layout from "@/layouts/main.astro"

const features = [
  ["Detect real modes", "Find complete Tailwind 4 theme surfaces across :root, class selectors, body classes, and data-theme attributes."],
  ["Edit with context", "Change OKLCH colors, radius, shadows, typography, and raw CSS while previewing the result against the page."],
  ["Preserve presets", "Save imported or hand-tuned themes locally so the same palette is ready the next time you open the browser."],
  ["Export clean CSS", "Copy the whole theme or a single mode when you are ready to move changes back into your project."],
]

const steps = [
  "Open the embedded demo or any supported Tailwind site.",
  "WindPanel reads the active mode from the page state.",
  "Tune variables, switch modes, import CSS, or apply presets.",
  "Copy the final theme back into your codebase.",
]
---

<Layout title="WindPanel - Tailwind theme editor">
  <main class="landing-shell">
    <section class="hero">
      <nav class="topbar" aria-label="Primary">
        <a class="brand" href="/">
          <img src="/windpanel-icon.png" alt="" />
          <span>WindPanel</span>
        </a>
        <a href="/embedded-demo">Embedded demo</a>
      </nav>

      <div class="hero-grid">
        <div class="hero-copy">
          <p class="kicker">Tailwind 4 theme workbench</p>
          <h1>Inspect and tune live CSS variables without leaving the page.</h1>
          <p class="lede">
            WindPanel detects complete Tailwind theme modes, gives you a focused editing panel, and keeps the website state as the
            source of truth while you test colors, presets, fonts, radius, shadows, and raw CSS.
          </p>
          <div class="hero-actions">
            <a class="primary-cta" href="https://chromewebstore.google.com/" target="_blank" rel="noreferrer">Install from Chrome</a>
            <a class="secondary-cta" href="/embedded-demo">View embedded demo</a>
            <span>Browser extension build: local-first, no remote code.</span>
          </div>
        </div>

        <div class="product-demo" data-product-demo>
          <div class="website-card" data-site-preview>
            <div class="window-bar" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="website-content">
              <p>Live website</p>
              <h2>Theme surface</h2>
              <div class="sample-row">
                <span data-token="primary"></span>
                <span data-token="accent"></span>
                <span data-token="background"></span>
              </div>
              <div class="sample-chart" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>
          </div>

          <aside class="mini-panel">
            <div class="mini-head">
              <img src="/windpanel-icon.png" alt="" />
              <div>
                <span>WindPanel</span>
                <strong>Variables</strong>
              </div>
            </div>
            <div class="mini-segments" aria-label="Preview theme">
              <button type="button" class="active" data-preview-mode="light">Light</button>
              <button type="button" data-preview-mode="dark">Dark</button>
              <button type="button" data-preview-mode="dim">Dim</button>
            </div>
            <div class="mini-tokens">
              <div><span data-dot="primary"></span><code>--primary</code></div>
              <div><span data-dot="accent"></span><code>--accent</code></div>
              <div><span data-dot="background"></span><code>--background</code></div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="metric-strip" aria-label="Extension highlights">
      <div><strong>Tailwind 4</strong><span>@theme inline and CSS variable workflows</span></div>
      <div><strong>Mode-aware</strong><span>Light, dark, data-theme, and custom selectors</span></div>
      <div><strong>Local-first</strong><span>Presets stay in browser extension storage</span></div>
    </section>

    <section class="feature-section">
      <p class="kicker">What it handles</p>
      <div class="feature-grid">
        {
          features.map(([title, copy]) => (
            <article>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="workflow-section">
      <div class="section-copy">
        <p class="kicker">Workflow</p>
        <h2>Made for testing a theme where it will actually be used.</h2>
      </div>
      <ol>
        {
          steps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{step}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="demo-callout">
      <div>
        <p class="kicker">Try it now</p>
        <h2>Open the embedded component demo.</h2>
        <p>
          The demo mounts the same Svelte panel inside Astro and exposes multiple complete theme modes so you can test detection,
          mode switching, variable edits, presets, and CSS export without installing the extension first.
        </p>
      </div>
      <a href="/embedded-demo">Launch embedded demo</a>
    </section>

    <section class="extension-info">
      <div>
        <p class="kicker">Extension details</p>
        <h2>Built for developers editing Tailwind systems.</h2>
      </div>
      <dl>
        <div>
          <dt>Permissions</dt>
          <dd>Uses storage for saved presets and page access to inspect theme variables on the current website.</dd>
        </div>
        <div>
          <dt>Data model</dt>
          <dd>Reads CSS custom properties, mode selectors, and active HTML/body state. Presets are stored locally.</dd>
        </div>
        <div>
          <dt>Best fit</dt>
          <dd>Tailwind 4, shadcn-style CSS variables, OKLCH palettes, and teams iterating on brand themes in-browser.</dd>
        </div>
      </dl>
    </section>

    <footer class="footer">
      <a class="brand" href="/">
        <img src="/windpanel-icon.png" alt="" />
        <span>WindPanel</span>
      </a>
      <p>Tailwind theme inspection, presets, and variable editing for modern CSS workflows.</p>
      <a href="/embedded-demo">Embedded demo</a>
    </footer>
  </main>

  <script>
    const palettes = {
      light: {
        page: "#fffaf0",
        card: "#ffffff",
        text: "#17130f",
        muted: "#6a5f51",
        primary: "oklch(0.49 0.27 292.58)",
        accent: "oklch(0.9 0.2 126.66)",
        background: "oklch(0.94 0.04 83)",
      },
      dark: {
        page: "#16130f",
        card: "#241f19",
        text: "#fffaf0",
        muted: "#b8ad9d",
        primary: "oklch(0.68 0.2 292)",
        accent: "oklch(0.72 0.14 155)",
        background: "oklch(0.22 0.02 65)",
      },
      dim: {
        page: "#13212a",
        card: "#1d303b",
        text: "#eaf6f7",
        muted: "#9fb5bb",
        primary: "oklch(0.68 0.17 230)",
        accent: "oklch(0.7 0.14 190)",
        background: "oklch(0.25 0.025 245)",
      },
    }

    const demo = document.querySelector("[data-product-demo]")
    const buttons = document.querySelectorAll("[data-preview-mode]")
    function applyPreviewMode(mode) {
      const palette = palettes[mode] || palettes.light
      demo?.style.setProperty("--demo-page", palette.page)
      demo?.style.setProperty("--demo-card", palette.card)
      demo?.style.setProperty("--demo-text", palette.text)
      demo?.style.setProperty("--demo-muted", palette.muted)
      demo?.style.setProperty("--demo-primary", palette.primary)
      demo?.style.setProperty("--demo-accent", palette.accent)
      demo?.style.setProperty("--demo-background", palette.background)

      for (const button of buttons) {
        button.classList.toggle("active", button.getAttribute("data-preview-mode") === mode)
      }
    }

    for (const button of buttons) {
      button.addEventListener("click", () => applyPreviewMode(button.getAttribute("data-preview-mode") || "light"))
    }

    applyPreviewMode("light")
  </script>
</Layout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #f7f2e8;
  }

  .landing-shell {
    --radius: 16px;
    --paper: #f7f2e8;
    --ink: #16130f;
    --muted: #6c6254;
    --line: rgba(22, 19, 15, 0.13);
    --surface: #fffaf0;
    min-height: 100svh;
    padding-bottom: 24px;
    background: var(--paper);
    color: var(--ink);
    font-family: "Geist Variable", ui-sans-serif, system-ui, sans-serif;
  }

  .hero,
  .metric-strip,
  .feature-section,
  .workflow-section,
  .demo-callout,
  .extension-info,
  .footer {
    width: min(1160px, calc(100% - 40px));
    margin: 0 auto;
  }

  .hero {
    padding: 22px 0 52px;
  }

  .topbar,
  .brand,
  .hero-actions,
  .mini-head,
  .mini-tokens div,
  .footer {
    display: flex;
    align-items: center;
  }

  .topbar {
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 34px;
  }

  .brand {
    gap: 10px;
    color: inherit;
    font-weight: 900;
    text-decoration: none;
  }

  .brand img,
  .mini-head img {
    width: 36px;
    height: 36px;
  }

  .topbar > a:not(.brand),
  .footer > a:not(.brand) {
    color: var(--ink);
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1fr);
    gap: 36px;
    align-items: center;
    min-width: 0;
  }

  .kicker {
    margin: 0;
    color: #77623d;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy h1,
  .section-copy h2,
  .demo-callout h2,
  .extension-info h2 {
    margin: 10px 0 0;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .hero-copy h1 {
    max-width: 680px;
    font-size: clamp(42px, 5.8vw, 74px);
  }

  .hero-copy,
  .product-demo {
    min-width: 0;
  }

  .lede {
    max-width: 620px;
    margin: 20px 0 0;
    color: #3d352b;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.45;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 26px;
  }

  .primary-cta,
  .secondary-cta,
  .demo-callout a {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--ink);
    color: #fffaf0;
    padding: 0 18px;
    font-size: 14px;
    font-weight: 900;
    text-decoration: none;
  }

  .secondary-cta {
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink);
  }

  .hero-actions span {
    max-width: 260px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.4;
  }

  .product-demo {
    --demo-page: #fffaf0;
    --demo-card: #ffffff;
    --demo-text: #17130f;
    --demo-muted: #6a5f51;
    --demo-primary: oklch(0.49 0.27 292.58);
    --demo-accent: oklch(0.9 0.2 126.66);
    --demo-background: oklch(0.94 0.04 83);
    position: relative;
    display: grid;
    min-height: 430px;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--demo-page) 88%, white);
    box-shadow: 0 24px 70px rgba(42, 34, 22, 0.16);
    transition: background 180ms ease;
  }

  .website-card,
  .mini-panel,
  .feature-grid article,
  .workflow-section li,
  .demo-callout,
  .extension-info,
  .metric-strip,
  .footer {
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .website-card {
    overflow: hidden;
    background: var(--demo-card);
    color: var(--demo-text);
    transition:
      background 180ms ease,
      color 180ms ease;
  }

  .window-bar {
    display: flex;
    gap: 7px;
    padding: 14px;
    border-bottom: 1px solid var(--line);
  }

  .window-bar span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.18;
  }

  .website-content {
    padding: 28px;
  }

  .website-content p,
  .mini-head span {
    margin: 0;
    color: var(--demo-muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .website-content h2 {
    max-width: 360px;
    margin: 8px 0 0;
    font-size: clamp(34px, 6vw, 62px);
    line-height: 0.95;
  }

  .sample-row {
    display: flex;
    gap: 10px;
    margin-top: 28px;
  }

  .sample-row span,
  .mini-tokens span {
    background: var(--demo-primary);
  }

  .sample-row span {
    width: 86px;
    height: 56px;
    border-radius: 12px;
  }

  .sample-row span:nth-child(2),
  .mini-tokens [data-dot="accent"] {
    background: var(--demo-accent);
  }

  .sample-row span:nth-child(3),
  .mini-tokens [data-dot="background"] {
    background: var(--demo-background);
  }

  .sample-chart {
    display: flex;
    align-items: end;
    gap: 8px;
    height: 110px;
    margin-top: 28px;
  }

  .sample-chart span {
    width: 42px;
    border-radius: 10px 10px 0 0;
    background: var(--demo-accent);
  }

  .sample-chart span:nth-child(1) {
    height: 84%;
  }

  .sample-chart span:nth-child(2) {
    height: 58%;
    background: var(--demo-primary);
  }

  .sample-chart span:nth-child(3) {
    height: 74%;
  }

  .sample-chart span:nth-child(4) {
    height: 42%;
    background: var(--demo-primary);
  }

  .mini-panel {
    position: absolute;
    right: 28px;
    bottom: 28px;
    width: min(330px, calc(100% - 56px));
    padding: 14px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 18px 60px rgba(31, 24, 15, 0.18);
    backdrop-filter: blur(18px);
  }

  .mini-head {
    gap: 10px;
  }

  .mini-head strong {
    display: block;
    margin-top: 2px;
    font-size: 20px;
  }

  .mini-segments {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin-top: 14px;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #ece7dc;
  }

  .mini-segments button {
    min-height: 32px;
    border: 0;
    border-radius: 9px;
    background: transparent;
    color: #3d352b;
    font: inherit;
    font-size: 12px;
    font-weight: 900;
  }

  .mini-segments button.active {
    background: #fffaf0;
    box-shadow: 0 1px 4px rgba(22, 19, 15, 0.12);
  }

  .mini-tokens {
    display: grid;
    gap: 9px;
    margin-top: 14px;
  }

  .mini-tokens div {
    gap: 10px;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fffaf0;
  }

  .mini-tokens span {
    width: 30px;
    height: 30px;
    border-radius: 9px;
  }

  .mini-tokens code {
    color: #17130f;
    font-size: 12px;
    font-weight: 800;
  }

  .metric-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 10px;
    overflow: hidden;
    background: var(--surface);
  }

  .metric-strip div {
    padding: 18px;
  }

  .metric-strip div + div {
    border-left: 1px solid var(--line);
  }

  .metric-strip strong,
  .metric-strip span {
    display: block;
  }

  .metric-strip strong {
    font-size: 15px;
  }

  .metric-strip span {
    margin-top: 5px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.35;
  }

  .feature-section,
  .workflow-section,
  .extension-info {
    padding: 64px 0 0;
  }

  .feature-intro {
    display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(0, 1fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 14px;
  }

  .feature-title-card,
  .feature-summary-card {
    min-height: 220px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .feature-title-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 24px;
  }

  .feature-summary-card {
    display: grid;
    align-content: space-between;
    gap: 24px;
    padding: 24px;
  }

  .feature-summary-card p {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 23px);
    line-height: 1.35;
  }

  .summary-points {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
  }

  .summary-points span {
    display: grid;
    min-height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink);
    font-size: 13px;
    font-weight: 900;
  }

  .section-copy {
    display: grid;
    grid-template-columns: 0.78fr 1fr;
    gap: 32px;
    align-items: end;
    margin-bottom: 18px;
  }

  .section-copy h2,
  .feature-intro h2,
  .demo-callout h2,
  .extension-info h2 {
    max-width: 720px;
    font-size: clamp(32px, 5vw, 58px);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .feature-grid article {
    min-height: 210px;
    padding: 18px;
    background: var(--surface);
  }

  .feature-grid h3 {
    margin: 0;
    font-size: 21px;
  }

  .feature-grid p,
  .demo-callout p,
  .extension-info dd,
  .footer p {
    color: var(--muted);
    line-height: 1.5;
  }

  .feature-grid p {
    margin: 14px 0 0;
    font-size: 14px;
  }

  .workflow-section {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 34px;
  }

  .workflow-section .section-copy {
    display: block;
    margin: 0;
  }

  .workflow-section ol {
    display: grid;
    gap: 10px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .workflow-section li {
    display: grid;
    grid-template-columns: 54px 1fr;
    gap: 14px;
    align-items: center;
    padding: 16px;
    background: var(--surface);
  }

  .workflow-section li span {
    color: #77623d;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 900;
  }

  .workflow-section li p {
    margin: 0;
    font-weight: 800;
  }

  .demo-callout {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 28px;
    align-items: end;
    margin-top: 64px;
    padding: 24px;
    background: #17130f;
    color: #fffaf0;
  }

  .demo-callout p {
    max-width: 680px;
    margin: 16px 0 0;
    color: #d8cfc0;
  }

  .demo-callout a {
    background: #fffaf0;
    color: #17130f;
  }

  .extension-info {
    display: grid;
    grid-template-columns: 0.8fr 1fr;
    gap: 34px;
  }

  .extension-info {
    border: 0;
  }

  .extension-info dl {
    display: grid;
    gap: 10px;
    margin: 0;
  }

  .extension-info dl div {
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .extension-info dt {
    font-weight: 900;
  }

  .extension-info dd {
    margin: 6px 0 0;
    font-size: 14px;
  }

  .footer {
    justify-content: space-between;
    gap: 18px;
    margin-top: 64px;
    margin-bottom: 0;
    padding: 18px;
    background: var(--surface);
  }

  .footer p {
    max-width: 520px;
    margin: 0;
    font-size: 14px;
  }

  @media (max-width: 960px) {
    .hero-grid,
    .feature-intro,
    .section-copy,
    .workflow-section,
    .extension-info,
    .demo-callout {
      grid-template-columns: 1fr;
    }

    .product-demo {
      min-height: 390px;
    }

    .feature-grid,
    .metric-strip {
      grid-template-columns: repeat(2, 1fr);
    }

    .metric-strip div + div {
      border-left: 0;
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 620px) {
    .hero,
    .metric-strip,
    .feature-section,
    .workflow-section,
    .demo-callout,
    .extension-info,
    .footer {
      width: min(100% - 24px, 1160px);
    }

    .topbar,
    .footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-copy h1 {
      max-width: 330px;
      font-size: 30px;
      line-height: 1.04;
    }

    .hero-copy {
      width: 100%;
      max-width: calc(100vw - 24px);
    }

    .lede {
      max-width: 330px;
      font-size: 16px;
    }

    .hero-actions {
      display: grid;
      width: min(100%, 330px);
      grid-template-columns: 1fr;
    }

    .primary-cta,
    .secondary-cta {
      width: 100%;
    }

    .product-demo {
      min-height: 520px;
    }

    .mini-panel {
      right: 14px;
      bottom: 14px;
      width: calc(100% - 28px);
    }

    .website-content {
      padding: 20px;
    }

    .website-content h2 {
      font-size: 40px;
    }

    .feature-grid,
    .feature-intro,
    .metric-strip {
      grid-template-columns: 1fr;
    }

    .feature-title-card,
    .feature-summary-card {
      min-height: auto;
    }

    .summary-points {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
